{
  "name": "marketimmune-dashboard",
  "version": "1.0.0",
  "description": "Agentic market-safety research platform for crypto perps with a terminal dashboard, audited immune loop, and markout evaluation roadmap.",
  "private": true,
  "scripts": {
    "dev": "python manage.py runserver",
    "dev:frontend": "npm run dev --prefix frontend",
    "build": "npm run build --prefix frontend",
    "typecheck": "npm run typecheck --prefix frontend",
    "preview": "npm run preview --prefix frontend",
    "collect": "python manage.py collectstatic --noinput",
    "migrate": "python manage.py migrate",
    "load-data": "python manage.py load_metrics",
    "setup:frontend": "npm install --prefix frontend",
    "setup:backend": "pip install -r dashboard/requirements.txt",
    "setup": "npm run setup:frontend && npm run setup:backend && python manage.py migrate && python manage.py load_metrics"
  },
  "keywords": [
    "benchmark",
    "dashboard",
    "django",
    "visualization",
    "trading",
    "market-immune",
    "hyperliquid",
    "adverse-selection",
    "agentic-ai"
  ],
  "author": "MarketImmune Team",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
