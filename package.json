{
  "name": "marketimmune-dashboard",
  "version": "1.0.0",
  "description": "Interactive web dashboard for MarketImmune benchmark visualization",
  "main": "dashboard/static/js/dashboard.js",
  "scripts": {
    "dev": "python manage.py runserver",
    "build": "tsc",
    "watch": "tsc --watch",
    "collect": "python manage.py collectstatic --noinput",
    "migrate": "python manage.py migrate",
    "load-data": "python manage.py load_metrics",
    "setup": "npm install && pip install -r dashboard/requirements.txt && python manage.py migrate && python manage.py load_metrics"
  },
  "keywords": [
    "benchmark",
    "dashboard",
    "django",
    "visualization",
    "trading",
    "market-immume"
  ],
  "author": "MarketImmune Team",
  "license": "MIT",
  "devDependencies": {
    "@types/chart.js": "^4.4.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "axios": "^1.4.0",
    "chart.js": "^4.4.0"
  },
  "engines": {
    "node": ">=14.0.0",
    "npm": ">=6.0.0",
    "python": ">=3.8"
  }
}
