# MarketImmune environment configuration template.
# Copy to `.env` and fill in real values. `.env` is gitignored.

# ---------------------------------------------------------------------------
# DeepSeek — used by the agentic immune loop for richer reasoning.
# OpenAI-compatible API (https://api.deepseek.com). Without these, agents fall
# back to the deterministic NullLLMClient.
# ---------------------------------------------------------------------------
# Get a key at https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=

# Provider selector. "deepseek" is the only provider shipped today; the factory
# leaves room to register more without touching the agents.
MARKETIMMUNE_LLM_PROVIDER=deepseek

# Model id. deepseek-v4-pro = top reasoning/agentic tier;
# deepseek-v4-flash = cheaper, faster iteration.
DEEPSEEK_MODEL=deepseek-v4-pro

# Optional overrides.
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MAX_TOKENS=4000

# Set to "1" to actually enable LLM calls. Without this flag the project behaves
# exactly as the deterministic baseline even when an API key is present.
MARKETIMMUNE_USE_LLM=0

# ---------------------------------------------------------------------------
# Hyperliquid live strip — free public Info API, no key required.
# ---------------------------------------------------------------------------
# Instrument for `/api/hyperliquid/live/`. The frontend does not choose a coin.
MARKETIMMUNE_HYPERLIQUID_COIN=BTC

# Server freshness budget for live Hyperliquid calls. Use data-first defaults;
# lower this only after the API is reliably loading on your machine.
MARKETIMMUNE_HYPERLIQUID_BUDGET_MS=2000

# Short local cache so repeated page polls can stay fast without fake values.
MARKETIMMUNE_HYPERLIQUID_CACHE_TTL_MS=5000

# Recent candles used by the Live Market chart.
MARKETIMMUNE_HYPERLIQUID_CANDLE_INTERVAL=1m
MARKETIMMUNE_HYPERLIQUID_CANDLE_LOOKBACK_MINUTES=240
MARKETIMMUNE_HYPERLIQUID_CANDLE_CACHE_TTL_MS=30000

# Optional browser polling knobs. Vite reads this repo-root `.env`, but only
# exposes VITE_* values to the browser. Leave the budget unset so Django's
# MARKETIMMUNE_HYPERLIQUID_BUDGET_MS remains the single request-time source.
VITE_MARKETIMMUNE_HYPERLIQUID_BUDGET_MS=
VITE_MARKETIMMUNE_HYPERLIQUID_POLL_MS=5000
VITE_MARKETIMMUNE_HYPERLIQUID_CANDLE_POLL_MS=30000
VITE_MARKETIMMUNE_HYPERLIQUID_CANDLE_INTERVAL=1m
VITE_MARKETIMMUNE_HYPERLIQUID_CANDLE_LOOKBACK_MINUTES=240
