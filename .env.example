# MarketImmune environment configuration template.
# Copy to `.env` and fill in real values. `.env` is gitignored.

# ---------------------------------------------------------------------------
# Anthropic Claude — used by the agentic immune loop for richer reasoning.
# Without these, agents fall back to the deterministic NullLLMClient.
# ---------------------------------------------------------------------------
# Get a key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Model id. Defaults to the latest Sonnet released at the time of writing.
# Override here if you want to use Haiku for cheaper iteration or Opus for
# higher-quality scenarios.
CLAUDE_MODEL=claude-sonnet-4-20250514
# Set to "1" to actually enable LLM calls. Without this flag the project
# behaves exactly as it does in the screen-recording demo (deterministic
# baseline), even when an API key is present. Use this to A/B compare.
MARKETIMMUNE_USE_LLM=0

# Thinking budget for extended-thinking mode (tokens). Higher = more
# deliberate reasoning per call, slower, more expensive.
CLAUDE_THINKING_BUDGET=2000

# Hard cap on output tokens. Must be larger than CLAUDE_THINKING_BUDGET.
CLAUDE_MAX_TOKENS=4000
